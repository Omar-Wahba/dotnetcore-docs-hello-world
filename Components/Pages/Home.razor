@page "/"
@rendermode InteractiveServer

<PageTitle>For Manona ❤️</PageTitle>

<div class="romance-page">

    <div class="hearts" aria-hidden="true">
        @for (int i = 0; i < heartCount; i++)
        {
            <span class="heart heart-@(i % 8)">❤</span>
        }
    </div>

    <main class="romance-card fade-in">
        <p class="eyebrow">A little something for you</p>

        <h1 class="main-message">
            Love you <span class="name">Manona</span> <span class="emoji-heart">❤️</span>
        </h1>

        <p class="quote">
            &ldquo;In a sea of people, my eyes will always search for you.&rdquo;
        </p>
        <div class="photo-frame">
        <div class="photo-frame">
    <img src="@Assets["photo.jpeg"]" alt="Omar and Manona" class="us-photo" />
</div>
</div>

        <div class="divider"><span>♡</span></div>

        <div class="divider"><span>♡</span></div>

        @if (!isRevealed)
        {
            <button class="reveal-btn" @onclick="Reveal">
                Tap for a secret message
            </button>
        }
        else
        {
            <div class="secret-message fade-in">
                <p>
                    Every day with you feels like a page from my favorite story —
                    warm, gentle, and exactly where I want to be. Thank you for
                    being you. Here's to us, always. 💕
                </p>
                <span class="signature">— forever yours</span>
            </div>
        }
        @if (!isProposalRevealed)
{
    <button class="reveal-btn reveal-btn-secondary" @onclick="RevealProposal">
        One more secret 💍
    </button>
}
else
{
    <div class="proposal-message fade-in">
        <p>You will be my Wife one day Inshaallah! <span class="proposal-heart">❤️</span></p>
    </div>
}
        <div class="footer-hearts" aria-hidden="true">
            <span>❤</span><span>❤</span><span>❤</span>
        </div>
    </main>

</div>

@code {
    private bool isRevealed = false;
    private bool isProposalRevealed = false;
    private const int heartCount = 18;

    private void Reveal()
    {
        isRevealed = true;
    }

    private void RevealProposal()
    {
        isProposalRevealed = true;
    }
}
}
